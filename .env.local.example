# ─── Supabase ─────────────────────────────────────────────────────────────────
# Cliente (público por design — anon key). Usado pelo formulário de cadastro.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only (service role — NUNCA expor no cliente). Usado por: /api/eventos,
# /api/checkin, /api/webhook/asaas, /api/checkout/validate-coupon (DB), /api/professores/clientes.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Google Maps (Embed/JS API) ───────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ─── Asaas (checkout/pagamentos) ──────────────────────────────────────────────
# Header de auth é `access_token` (não Bearer); base hard-coded https://api.asaas.com/v3.
ASAAS_API_KEY=
# Opcional: split/wallet (a GESTÃO lê mas não aplica split hoje).
ASAAS_WALLET_ID=
# Token do webhook Asaas (OBRIGATÓRIO para /api/webhooks/asaas funcionar).
ASAAS_WEBHOOK_TOKEN=

# ─── Cupons (registro de resgate via POST — opcional) ─────────────────────────
# Espelha CHECKOUT_API_SECRET da GESTÃO. Só necessário se ativarmos o POST de resgate.
CHECKOUT_API_SECRET=
